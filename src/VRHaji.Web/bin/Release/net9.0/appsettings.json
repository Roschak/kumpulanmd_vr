{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=VRHaji.db"
  },
  "ThreeJS": {
    "MaxTextureSize": 2048,
    "EnableShadows": true,
    "DefaultCameraFOV": 60,
    "RenderScale": 1.0
  },
  "Performance": {
    "TargetFPS": 60,
    "EnableLOD": true,
    "MaxDrawDistance": 200,
    "EnableFrustumCulling": true
  },
  "Audio": {
    "NaratorVolume": 0.8,
    "AmbientVolume": 0.5,
    "EffectVolume": 0.7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
